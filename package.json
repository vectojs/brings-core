{
  "name": "@vectojs/brings-core",
  "version": "0.2.0",
  "description": "Pure local-first vector document, geometry, history, and interchange primitives for Brings.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vectojs/brings-core.git"
  },
  "bugs": {
    "url": "https://github.com/vectojs/brings-core/issues"
  },
  "homepage": "https://brings-website.vectojs.org/",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --clean && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint --deny-warnings src test",
    "verify": "bun run format:check && bun run lint && bun run typecheck && bun test && bun run build && npm pack --dry-run",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint",
    "changeset": "changeset",
    "changeset:version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/bun": "^1.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "tsup": "^8.3.5",
    "typescript": "^7.0.2"
  }
}
